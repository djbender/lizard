<% content_for :title, "Login" %>

<% content_for :header do %>
  <h1>🦎 Lizard</h1>
<% end %>

<% content_for :no_footer, true %>

<div class="login-card">
  <%= form_with url: login_path, method: :post, local: true do |form| %>
    <p>
      <%= form.label :password, "Enter site password:" %>
      <%= form.password_field :password, required: true, autofocus: true %>
    </p>

    <p>
      <%= form.submit "Login" %>
    </p>
  <% end %>
</div>

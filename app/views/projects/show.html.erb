<% content_for :title, "#{@project.name} - Test Metrics" %>

<section style="width: 100vw; margin-left: calc(-50vw + 50%); padding: 0 2rem;">
  <nav aria-label="breadcrumb">
    <%= link_to "Dashboard", root_path %> →
    <%= link_to "Projects", projects_path %> →
    <%= @project.name %>
  </nav>
</section>

<section style="width: 100vw; margin-left: calc(-50vw + 50%); margin-bottom: 2rem;">
  <canvas data-controller="metrics-chart" data-metrics-chart-url-value="<%= metrics_project_path(@project) %>"></canvas>
</section>

<section>
  <h1><%= @project.name %></h1>

  <div class="project-details">
    <h2>Project Details</h2>
    <table>
      <tbody>
        <tr>
          <td><strong>Name:</strong></td>
          <td><%= @project.name %></td>
        </tr>
        <tr>
          <td><strong>API Key:</strong></td>
          <td data-controller="api-key-toggle">
            <code data-api-key-toggle-target="truncated" data-action="click->api-key-toggle#toggle" style="cursor: pointer;" title="Click to reveal full API key">
              <%= @project.api_key[0..10] %>...
            </code>
            <code data-api-key-toggle-target="full" data-action="click->api-key-toggle#toggle" style="cursor: pointer;" title="Click to hide API key" hidden>
              <%= @project.api_key %>
            </code>
          </td>
        </tr>
        <tr>
          <td><strong>Created:</strong></td>
          <td><%= @project.created_at.strftime('%Y-%m-%d %H:%M:%S') %></td>
        </tr>
        <tr>
          <td><strong>Updated:</strong></td>
          <td><%= @project.updated_at.strftime('%Y-%m-%d %H:%M:%S') %></td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<section>
  <h2>Recent Test Runs</h2>
  <%= turbo_frame_tag "test_runs" do %>
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Branch</th>
          <th>Ruby Specs</th>
          <th>JS Specs</th>
          <th>Coverage</th>
          <th>Runtime</th>
          <th>CI Run</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_runs.each do |run| %>
          <tr id="<%= dom_id(run) %>">
            <td><%= run.ran_at.strftime('%Y-%m-%d %H:%M') %></td>
            <td><%= run.branch %></td>
            <td><%= run.ruby_specs %></td>
            <td><%= run.js_specs %></td>
            <td><%= number_to_percentage(run.coverage, precision: 1) %></td>
            <td><%= number_with_precision(run.runtime, precision: 1) %>s</td>
            <td>
              <% if (url = github_actions_url(run.metadata)) %>
                <%= link_to run.metadata["github_run_id"], url, target: "_blank", rel: "noopener" %>
              <% end %>
            </td>
            <td>
              <%= button_to "Delete", project_test_run_path(@project, run), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this test run?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <%= raw @pagy.series_nav %>
  <% end %>
</section>
